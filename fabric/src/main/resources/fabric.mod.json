{
  "schemaVersion": 1,
  "id": "hexssence",
  "version": "${version}",
  "name": "Hexssence",
  "description": "Resource generation addon for Hex Casting",
  "authors": [
    "IllinaBurlace"
  ],
  "contact": {
    "homepage": "https://illinaburlace.github.io/Hexssence",
    "sources": "https://github.com/IllinaBurlace/Hexssence"
  },
  "license": "MIT",
  "icon": "assets/hexssence/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [{
      "adapter": "kotlin",
      "value": "meow.illina.hexssence.fabric.FabricHexssence"
    }],
    "client": [{
      "adapter": "kotlin",
      "value": "meow.illina.hexssence.fabric.FabricHexssenceClient"
    }],
    "server": [{
      "adapter": "kotlin",
      "value": "meow.illina.hexssence.fabric.FabricHexssenceServer"
    }],
    "fabric-datagen": [{
      "adapter": "kotlin",
      "value": "meow.illina.hexssence.fabric.datagen.FabricHexssenceDatagen"
    }],
    "modmenu": [{
      "adapter": "kotlin",
      "value": "meow.illina.hexssence.fabric.FabricHexssenceModMenu"
    }]
  },
  "mixins": [
    "hexssence-common.mixins.json",
    "hexssence-fabric.mixins.json"
  ],
  "depends": {
    "minecraft": "${versions.minecraft}",
    "fabricloader": ">=${versions.fabric_loader}",
    "fabric-api": ">=${versions.fabric_api}",
    "fabric-language-kotlin": ">=${versions.kotlin_fabric}",
    "architectury": ">=${versions.architectury}",
    "hexcasting": ">=${versions.hexcasting}",
    "cloth-config": ">=${versions.clothConfig}"
  },
  "suggests": {
    "modmenu": ">=${versions.modMenu}"
  }
}
